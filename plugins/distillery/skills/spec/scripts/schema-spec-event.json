{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "event_id", "created_at", "source", "use_cases", "cross_cutting", "stats"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[0-9]{6}_.+$",
      "minLength": 16
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/UseCase" }
    },
    "cross_cutting": {
      "$ref": "#/$defs/CrossCutting"
    },
    "stats": {
      "$ref": "#/$defs/Stats"
    }
  },
  "$defs": {
    "UseCase": {
      "type": "object",
      "required": ["business", "buc", "uc", "files"],
      "properties": {
        "business": { "type": "string", "minLength": 1 },
        "buc": { "type": "string", "minLength": 1 },
        "uc": { "type": "string", "minLength": 1 },
        "files": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" }
        },
        "api_count": { "type": "integer", "minimum": 0 },
        "async_event_count": { "type": "integer", "minimum": 0 }
      }
    },
    "CrossCutting": {
      "type": "object",
      "required": ["ux_design", "ui_design", "data_visualization"],
      "properties": {
        "ux_design": {
          "type": "object",
          "properties": {
            "user_flows": { "type": "integer", "minimum": 0 },
            "ia_pages": { "type": "integer", "minimum": 0 },
            "psychology_principles": { "type": "integer", "minimum": 0 }
          }
        },
        "ui_design": {
          "type": "object",
          "properties": {
            "layout_patterns": { "type": "integer", "minimum": 0 },
            "responsive_breakpoints": { "type": "integer", "minimum": 0 },
            "component_guidelines": { "type": "integer", "minimum": 0 }
          }
        },
        "data_visualization": {
          "type": "object",
          "properties": {
            "target_screens": { "type": "integer", "minimum": 0 },
            "chart_types": { "type": "integer", "minimum": 0 }
          }
        },
        "openapi": {
          "type": "object",
          "properties": {
            "api_count": { "type": "integer", "minimum": 0 }
          }
        },
        "asyncapi": {
          "type": "object",
          "properties": {
            "async_event_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "Stats": {
      "type": "object",
      "required": ["total_ucs", "total_apis"],
      "properties": {
        "total_ucs": { "type": "integer", "minimum": 1 },
        "total_apis": { "type": "integer", "minimum": 0 },
        "total_async_events": { "type": "integer", "minimum": 0 },
        "businesses": { "type": "integer", "minimum": 1 },
        "bucs": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
