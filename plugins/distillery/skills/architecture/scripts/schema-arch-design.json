{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "event_id", "created_at", "source", "technology_context", "system_architecture", "app_architecture", "data_architecture"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[0-9]{6}_.+$",
      "minLength": 16
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "technology_context": {
      "$ref": "#/$defs/TechnologyContext"
    },
    "system_architecture": {
      "$ref": "#/$defs/SystemArchitecture"
    },
    "app_architecture": {
      "$ref": "#/$defs/AppArchitecture"
    },
    "data_architecture": {
      "$ref": "#/$defs/DataArchitecture"
    }
  },
  "$defs": {
    "TechnologyContext": {
      "type": "object",
      "required": ["languages", "frameworks", "constraints"],
      "properties": {
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "frameworks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "SystemArchitecture": {
      "type": "object",
      "required": ["tiers", "cross_tier_policies", "cross_tier_rules", "diagram_mermaid"],
      "properties": {
        "tiers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Tier" }
        },
        "cross_tier_policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/Policy" }
        },
        "cross_tier_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Rule" }
        },
        "diagram_mermaid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Tier": {
      "type": "object",
      "required": ["id", "name", "description", "technology_candidates", "policies", "rules"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^tier-.+$",
          "minLength": 5
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "technology_candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/Policy" }
        },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Rule" }
        }
      }
    },
    "Policy": {
      "type": "object",
      "required": ["id", "name", "description", "reason", "source_model", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_model": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "default", "user"]
        }
      }
    },
    "Rule": {
      "type": "object",
      "required": ["id", "name", "description", "reason", "source_model", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_model": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "default", "user"]
        }
      }
    },
    "AppArchitecture": {
      "type": "object",
      "required": ["tier_layers"],
      "properties": {
        "tier_layers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TierLayer" }
        }
      }
    },
    "TierLayer": {
      "type": "object",
      "required": ["tier_id", "layers", "cross_layer_policies", "cross_layer_rules", "diagram_mermaid"],
      "properties": {
        "tier_id": {
          "type": "string",
          "minLength": 1
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Layer" }
        },
        "cross_layer_policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/Policy" }
        },
        "cross_layer_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Rule" }
        },
        "diagram_mermaid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Layer": {
      "type": "object",
      "required": ["id", "name", "responsibility", "allowed_dependencies", "policies", "rules"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "responsibility": {
          "type": "string",
          "minLength": 1
        },
        "allowed_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policies": {
          "type": "array",
          "items": { "$ref": "#/$defs/Policy" }
        },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/Rule" }
        }
      }
    },
    "DataArchitecture": {
      "type": "object",
      "required": ["entities", "storage_mapping", "diagram_mermaid"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Entity" }
        },
        "storage_mapping": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/StorageMapping" }
        },
        "diagram_mermaid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Entity": {
      "type": "object",
      "required": ["id", "name", "source_info", "model_type", "attributes", "relationships"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^E-[0-9]+$",
          "minLength": 3
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_info": {
          "type": "string",
          "minLength": 1
        },
        "model_type": {
          "type": "string",
          "enum": ["event_snapshot", "event", "resource_scd2", "resource_mutable"]
        },
        "attributes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Attribute" }
        },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/Relationship" }
        }
      }
    },
    "Attribute": {
      "type": "object",
      "required": ["name", "type", "description", "nullable", "primary_key"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "nullable": {
          "type": "boolean"
        },
        "primary_key": {
          "type": "boolean"
        }
      }
    },
    "Relationship": {
      "type": "object",
      "required": ["target_entity", "type", "description"],
      "properties": {
        "target_entity": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["1:1", "1:N", "N:1", "N:M"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "StorageMapping": {
      "type": "object",
      "required": ["entity_id", "storage_type", "reason", "confidence"],
      "properties": {
        "entity_id": {
          "type": "string",
          "minLength": 1
        },
        "storage_type": {
          "type": "string",
          "enum": ["rdb", "nosql", "cache", "file", "search"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "default", "user"]
        }
      }
    }
  }
}
