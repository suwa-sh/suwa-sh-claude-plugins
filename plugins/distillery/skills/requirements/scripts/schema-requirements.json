{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "USDM Requirements",
  "description": "USDM (Universal Specification Describing Manner) requirements.yaml のスキーマ定義",
  "type": "object",
  "required": ["version", "event_id", "created_at", "source", "system_name", "requirements"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[0-9]{6}_.+$",
      "description": "YYYYMMDD_HHMMSS_変更名 形式"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "system_name": {
      "type": "string",
      "minLength": 1,
      "description": "対象システムの名称"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/requirement" }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "required": ["id", "requirement", "reason", "priority", "specifications"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^REQ-[0-9]{3}$"
        },
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["must", "should", "could"]
        },
        "specifications": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/specification" }
        }
      }
    },
    "specification": {
      "type": "object",
      "required": ["id", "specification", "acceptance_criteria", "affected_models"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^SPEC-[0-9]{3}-[0-9]{2}$"
        },
        "specification": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "affected_models": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/affected_model" }
        }
      }
    },
    "affected_model": {
      "type": "object",
      "required": ["type", "action", "target"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["actor", "information", "state", "buc", "condition", "variation", "external_system", "business_policy"]
        },
        "action": {
          "type": "string",
          "enum": ["add", "modify", "delete"]
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
